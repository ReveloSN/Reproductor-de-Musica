{
  "name": "electron-music-player",
  "version": "1.0.0",
  "description": "Music player",
  "main": "dist/main.js",
  "scripts": {
    "clean:dist": "node scripts/clean-dist.cjs",
    "build:ts": "npm run clean:dist && tsc -p tsconfig.json && node scripts/copy-ui-static.cjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "npm run build:ts && electron .",
    "pack:win": "npm run build:ts && electron-builder --win --dir",
    "dist:win": "npm run build:ts && electron-builder --win nsis",
    "dist:portable": "npm run build:ts && electron-builder --win portable",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "JasonM",
  "license": "MIT",
  "packageManager": "pnpm@10.11.0",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "electron": "23.1.3",
    "electron-builder": "^26.0.12",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "music-metadata": "^11.12.3",
    "wavesurfer.js": "^7.12.6"
  },
  "build": {
    "appId": "com.revelosn.localaudioplayer",
    "productName": "Local Audio Player",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "dist/main.js"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true
    }
  }
}
