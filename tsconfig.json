{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "rootDir": ".",
    "outDir": "dist",
    "lib": ["DOM", "ES2020"],
    "types": ["node", "electron"],
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "noEmitOnError": true,
    "ignoreDeprecations": "6.0"
  },
  "include": [
    "global.d.ts",
    "main.ts",
    "menu.ts",
    "preload.ts",
    "UI/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "renderer"
  ]
}
